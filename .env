# Configuration Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Topics Kafka
TOPIC_SONG_PLAYS=song-plays
TOPIC_USER_EVENTS=user-events
TOPIC_SONG_METADATA=song-metadata
TOPIC_MOOD_INDEX=mood-index
TOPIC_GENRE_SIGNALS=genre-signals

# Chemins vers les données
DATA_DIR=./data
TRACKS_CSV=songs.csv
ARTISTS_CSV=artists.csv

# Paramètres du simulateur
SIMULATION_INTERVAL_MS=2000
NUM_SIMULATED_USERS=1000 #The system pretends there are 1000 different users

#API enrichement
LASTFM_API_KEY=94a16d0613a469d669240e9cd9a26a60
# Spark batch K-Means (Layer 3a)
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_APP_NAME=genre-kmeans-batch
SPARK_JARS_IVY=/tmp/.ivy2
SPARK_SQL_SHUFFLE_PARTITIONS=200
SPARK_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
SPARK_KAFKA_INPUT_TOPIC=song-metadata
SPARK_KAFKA_OUTPUT_TOPIC=genre-signals
SPARK_KAFKA_STARTING_OFFSETS=earliest
SPARK_KAFKA_ENDING_OFFSETS=latest
KMEANS_INPUT_MAX_ROWS=
SPARK_HADOOP_FS_DEFAULT_FS=hdfs://hdfs-namenode:8020
SPARK_BATCH_INPUT_MODE=hdfs_snapshot
SPARK_BATCH_INPUT_PATH=hdfs://hdfs-namenode:8020/data/song-metadata/*.jsonl
# K-Means tuning
KMEANS_CANDIDATE_KS=6,8,10,12
KMEANS_FINAL_K=
KMEANS_MAX_ITER=30
KMEANS_SEED=42
KMEANS_TOL=0.0001
KMEANS_SELECTION_SAMPLE_FRACTION=1.0

# PostgreSQL output (Layer 4)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=spotify_analytics
POSTGRES_USER=spotify_user
POSTGRES_PASSWORD=spotify_pass
POSTGRES_SCHEMA=analytics
PG_TABLE_BATCH_RUNS=batch_runs
PG_TABLE_CLUSTER_METRICS=cluster_metrics
PG_TABLE_SONG_CLUSTERS=song_clusters
PG_TABLE_CLUSTER_CENTROIDS=cluster_centroids
PG_TABLE_CLUSTER_PROFILES=cluster_profiles

# HDFS (WebHDFS access)
HDFS_WEBHDFS_BASE_URL=http://localhost:9870
HDFS_DATASET_DIR=/data/song-metadata
HDFS_SNAPSHOTS_DIR=snapshots
HDFS_INDEX_FILE=index.json